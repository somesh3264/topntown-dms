{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "crons": [
    {
      "path": "/api/cron/generate-bills",
      "schedule": "30 16 * * *"
    }
  ],

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
