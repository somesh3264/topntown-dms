# .env.local.example
# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ---------------------------------------------------------------------------

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project → Settings → API

# The public URL of your Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# The anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service-role key — SERVER ONLY, never prefix with NEXT_PUBLIC_
# Used only in trusted server contexts (e.g. admin scripts, Edge Functions).
# SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
